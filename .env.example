# Required before production smoke/release:
# 1. Run `nvm use && npm exec -- ampx sandbox` or deploy the Amplify backend.
# 2. Copy the generated `amplify_outputs.json` to the project root.
# 3. Run `bun run verify:amplify-config` and confirm Auth/Data/Storage sections exist.

# AI SDK / Amazon Bedrock
# Use AWS credentials that can invoke the configured Bedrock model.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# Optional
# AWS_SESSION_TOKEN=your-aws-session-token

# Optional local fallback: use libsql instead of Amplify Data.
# Production defaults to Amplify Data when this is unset.
# CHAT_STORE_RUNTIME=libsql
# CHAT_STORE_DATABASE_URL=file:./mastra.db

# Optional rollback fallback: use custom S3 attachment storage instead of Amplify Storage.
# Production defaults to Amplify Storage when this is unset.
# CHAT_BLOB_STORE_RUNTIME=s3
# CHAT_ATTACHMENTS_S3_BUCKET=your-fallback-bucket
# CHAT_ATTACHMENTS_S3_PREFIX=secondstream/attachments/
